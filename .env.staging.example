# Guardian AI — 스테이징(staging) 환경 변수
#
# 사용법:
#   1. 이 파일을 복사해 `.env.staging` 으로 저장 (실제 키 입력)
#   2. flutter build apk --release --dart-define-from-file=.env.staging
#
# `.env.staging` 은 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.

# [필수] Anthropic Claude API 키 (사내 테스트용 별도 키 권장)
ANTHROPIC_API_KEY=sk-ant-api03-여기에_스테이징_키_붙여넣기

# 참고용 환경 식별자 (코드에서 직접 참조하지는 않음)
APP_ENV=staging
