# Guardian AI — 개발(dev) 환경 변수
#
# 사용법:
#   1. 이 파일을 복사해 `.env.dev` 로 저장 (실제 키 입력)
#   2. flutter run --dart-define-from-file=.env.dev
#
# `.env.dev` 는 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.

# [필수] Anthropic Claude API 키
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-여기에_본인_키_붙여넣기

# 참고용 환경 식별자 (코드에서 직접 참조하지는 않음)
APP_ENV=dev
