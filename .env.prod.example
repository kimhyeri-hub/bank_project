# Guardian AI — 운영(prod) 환경 변수
#
# 사용법:
#   1. 이 파일을 복사해 `.env.prod` 로 저장 (실제 키 입력)
#   2. flutter build apk --release --dart-define-from-file=.env.prod
#
# `.env.prod` 는 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.

# [필수] Anthropic Claude API 키 (운영용 키 — dev/staging 키와 분리 권장)
ANTHROPIC_API_KEY=sk-ant-api03-여기에_운영_키_붙여넣기

# 참고용 환경 식별자 (코드에서 직접 참조하지는 않음)
APP_ENV=prod
